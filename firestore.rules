rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // MESTRE: Permissão total para o seu e-mail ou seu UID
    match /{document=**} {
      allow read, write: if request.auth != null && 
                          (request.auth.token.email == "jvssilv4@gmail.com" || 
                           request.auth.uid == "9C8HfL8AhqfR2Zl6uxEkjYBJo7Z2");
    }

    // Regras públicas para o funcionamento do site
    match /leads/{leadId} {
      allow create: if true;
    }

    match /analytics_events/{eventId} {
      allow create: if true;
    }

    match /site_content/{contentId} {
      allow read: if true;
    }
  }
}

