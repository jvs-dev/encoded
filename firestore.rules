rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check: using the specified admin email as a master admin
    function isMasterAdmin() { 
      return isSignedIn() && (
        (request.auth.token.keys().contains("email") && request.auth.token.email == "jvssilv4@gmail.com") || 
        request.auth.uid == "9C8HfL8AhqfR2Zl6uxEkjYBJo7Z2"
      ); 
    }
    
    function isAdmin() { 
      return isMasterAdmin() || 
             (isSignedIn() && exists(/databases/$(database)/documents/blog_users/$(request.auth.uid)) && get(/databases/$(database)/documents/blog_users/$(request.auth.uid)).data.role == 'admin') ||
             (isSignedIn() && request.auth.token.keys().contains("email") && exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())));
    }

    // --- Validation Blueprints ---
    function isValidBlogUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 8 && data.phoneNumber.size() <= 20 &&
             data.role in ['user', 'staff', 'client', 'admin'] &&
             data.isVerified is bool &&
             data.isIncoded is bool &&
             data.createdAt is timestamp;
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() >= 5 && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() >= 5 && data.slug.size() <= 250 &&
             data.content is string && data.content.size() >= 10 && data.content.size() <= 50000 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.createdAt is timestamp;
    }

    // --- Rules ---

    // Public/Existing Collections
    match /leads/{leadId} {
      allow create: if true; 
      allow read: if isAdmin();
    }
    match /analytics_events/{eventId} {
      allow create: if true;
      allow update: if true; // Allowed for duration tracking
    }
    match /site_content/{contentId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }
    match /prospects/{prospectId} {
      allow read, write: if isMasterAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isMasterAdmin();
    }

    match /briefing_forms/{formId} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    match /briefing_responses/{responseId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Blog Collections
    match /blog_users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidBlogUser(incoming()) &&
                      incoming().uid == request.auth.uid &&
                      incoming().role == 'user' &&
                      incoming().isVerified == false &&
                      incoming().isIncoded == false &&
                      incoming().createdAt == request.time;
      
      allow update: if (isMasterAdmin() && isValidBlogUser(incoming())) ||
                      (isOwner(userId) && 
                       isValidBlogUser(incoming()) &&
                       incoming().role == existing().role &&
                       incoming().isVerified == existing().isVerified &&
                       incoming().isIncoded == existing().isIncoded &&
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phoneNumber']));
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      isValidId(postId) &&
                      isValidBlogPost(incoming()) &&
                      incoming().authorId == request.auth.uid &&
                      incoming().createdAt == request.time &&
                      (isMasterAdmin() || 
                       (exists(/databases/$(database)/documents/blog_users/$(request.auth.uid)) && 
                        (isAdmin() || incoming().isSystemPost == false)
                       )
                      );
                      
      allow update: if (isAdmin() && isValidBlogPost(incoming())) ||
                      (isSignedIn() && 
                       (
                         // Normal post update by author
                         (existing().authorId == request.auth.uid &&
                          isValidBlogPost(incoming()) &&
                          incoming().authorId == existing().authorId &&
                          incoming().createdAt == existing().createdAt &&
                          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'slug', 'content', 'excerpt', 'coverImage', 'tags', 'updatedAt']) &&
                          incoming().updatedAt == request.time) ||
                         // Interaction: Likes (any signed in user)
                         (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'likedBy']) &&
                          (
                            (incoming().likesCount == existing().likesCount + 1 && incoming().likedBy.hasAll([request.auth.uid])) ||
                            (incoming().likesCount == existing().likesCount - 1 && !incoming().likedBy.hasAny([request.auth.uid]))
                          )
                         ) ||
                         // Interaction: Comments count (internal logic usually triggered by comment creation)
                         // For simplicity in this env, we allow the count to be incremented when a comment is added
                         (incoming().diff(existing()).affectedKeys().hasOnly(['commentsCount']) &&
                          incoming().commentsCount == existing().commentsCount + 1)
                       )
                      );
                       
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /blog_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().postId is string &&
                      incoming().content is string &&
                      incoming().content.size() > 0 &&
                      incoming().content.size() <= 1000 &&
                      incoming().createdAt == request.time;
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }
  }
}
