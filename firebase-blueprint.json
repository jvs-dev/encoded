{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A contact form submission from a potential client.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the lead" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number (optional)" },
        "message": { "type": "string", "description": "Message or inquiry details" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was created" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "description": "An event tracked for website analytics.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["page_view", "button_click", "section_view"], "description": "The type of event" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the event occurred" },
        "referrer": { "type": "string", "description": "The referrer URL (for page_view)" },
        "isMobile": { "type": "boolean", "description": "Whether the user is on a mobile device (for page_view)" },
        "duration": { "type": "number", "description": "Duration of the visit in seconds (for page_view)" },
        "buttonName": { "type": "string", "description": "Name of the button clicked (for button_click)" },
        "sectionName": { "type": "string", "description": "Name of the section viewed (for section_view)" }
      },
      "required": ["type", "timestamp"]
    },
    "SiteContent": {
      "title": "SiteContent",
      "description": "Dynamic content for the website.",
      "type": "object",
      "properties": {
        "adminPassword": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "servicesSubtitle": { "type": "string" },
        "processSubtitle": { "type": "string" },
        "portfolioSubtitle": { "type": "string" },
        "contactSubtitle": { "type": "string" },
        "faqSubtitle": { "type": "string" },
        "packagesSubtitle": { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" }
            }
          }
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" },
              "installments": { "type": "string" },
              "deliveryTime": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Collection of contact form submissions."
    },
    "/analytics_events/{eventId}": {
      "schema": { "$ref": "#/entities/AnalyticsEvent" },
      "description": "Collection of analytics events."
    },
    "/site_content/{contentId}": {
      "schema": { "$ref": "#/entities/SiteContent" },
      "description": "Collection of site content."
    }
  }
}
